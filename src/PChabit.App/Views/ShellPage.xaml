<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PChabit.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <NavigationView
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            ItemInvoked="NavView_ItemInvoked"
            PaneDisplayMode="Left"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

            <!-- 导航头部 -->
            <NavigationView.PaneHeader>
                <StackPanel
                    Padding="16,20"
                    Spacing="8">
                    <Image
                        Width="48"
                        Height="48"
                        Source="ms-appx:///Assets/Logo.png"
                        Stretch="Uniform" />
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PrimaryBrush}"
                        Text="PChabit" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <!-- 导航菜单项 -->
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="仪表盘"
                    Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Content="时间线"
                    Tag="Timeline">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Content="应用统计"
                    Tag="AppStats">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Content="键鼠详情"
                    Tag="KeyboardDetails">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE92E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Content="网页访问"
                    Tag="WebAccess">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- 分析 -->
                <NavigationViewItem
                    Content="分析"
                    Tag="Analytics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Content="数据管理"
                    Tag="DataManagement">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE88E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Content="目标管理"
                    Tag="Goals">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- 内容区域 -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Frame x:Name="ContentFrame" Grid.Row="0" />

                <!-- 状态栏 -->
                <Border
                    x:Name="StatusBar"
                    Grid.Row="1"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse
                                    x:Name="StatusIndicator"
                                    Width="10"
                                    Height="10"
                                    Fill="{StaticResource SuccessBrush}" />
                                <TextBlock
                                    x:Name="StatusText"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Text="监控中" />
                            </StackPanel>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="今日活跃: 5小时 32分钟" />
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                x:Name="ToggleMonitorButton"
                                Padding="12,6"
                                VerticalAlignment="Center"
                                Click="ToggleMonitorButton_Click"
                                Content="暂停监控"
                                CornerRadius="6"
                                FontSize="12"
                                Background="{StaticResource WarningBrush}"
                                Foreground="White" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
