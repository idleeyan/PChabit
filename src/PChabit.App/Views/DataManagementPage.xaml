<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PChabit.App.Views.DataManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:PChabit.App.Views"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer x:Name="ContentScrollViewer" Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="1100" HorizontalAlignment="Stretch">

                <!-- 页面标题 -->
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="数据管理" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="三种数据出口各司其职：本地备份用于灾难恢复、导出用于分析、云端用于异地容灾" />
                </StackPanel>

                <!-- 1. 数据概览 -->
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Glyph="&#xE9D9;"
                                    Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="数据概览" />
                            </StackPanel>
                            <Button
                                HorizontalAlignment="Right"
                                Click="RefreshOverview_Click"
                                Content="刷新" />
                        </Grid>

                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="数据库文件" />
                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.DatabaseSizeText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="总记录数" />
                                    <TextBlock FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Text="{x:Bind ViewModel.TotalRecordsText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="2" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="数据范围" />
                                    <TextBlock FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap">
                                        <Run Text="{x:Bind ViewModel.EarliestRecordText, Mode=OneWay}" />
                                        <Run Text=" ~ " />
                                        <Run Text="{x:Bind ViewModel.LatestRecordText, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="本地备份" />
                                    <TextBlock FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Text="{x:Bind ViewModel.LocalBackupsText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="云端备份" />
                                    <TextBlock FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Text="{x:Bind ViewModel.CloudBackupsText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="最近云同步" />
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind ViewModel.LastCloudSyncText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. 本地数据库备份（灾难恢复） -->
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Glyph="&#xE88E;"
                                    Foreground="#10B981" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="本地数据库备份（灾难恢复）" />
                            </StackPanel>
                            <TextBlock
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="ZIP 压缩整个 .db 文件，可一键还原" />
                        </Grid>

                        <Border
                            Padding="10"
                            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                            CornerRadius="6">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Text="用途：用于崩溃后整体恢复。备份包含数据库全部表，可直接替换运行中的数据库文件。系统每 4 小时自动备份一次，保留最近 7 份。" />
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Header="备份路径"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.BackupPath, Mode=TwoWay}" />
                            <Button
                                Grid.Column="1"
                                Content="浏览..."
                                VerticalAlignment="Bottom"
                                Click="BrowseBackupPath_Click" />
                        </Grid>

                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch
                                Header="自动备份"
                                IsOn="{x:Bind ViewModel.AutoBackupEnabled, Mode=TwoWay}" />
                            <NumberBox
                                Grid.Column="1"
                                Header="间隔（小时）"
                                Minimum="1"
                                Maximum="24"
                                SpinButtonPlacementMode="Inline"
                                Value="{x:Bind ViewModel.AutoBackupIntervalHours, Mode=TwoWay}" />
                            <NumberBox
                                Grid.Column="2"
                                Header="保留份数"
                                Minimum="1"
                                Maximum="30"
                                SpinButtonPlacementMode="Inline"
                                Value="{x:Bind ViewModel.MaxBackupCount, Mode=TwoWay}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Content="立即备份"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.CreateBackupCommand}" />
                            <ProgressBar
                                Width="220"
                                Value="{x:Bind ViewModel.BackupProgress, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsBackingUp, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                TextWrapping="Wrap"
                                Text="{x:Bind ViewModel.BackupStatus, Mode=OneWay}" />
                        </StackPanel>

                        <!-- 备份历史 -->
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="备份历史" />
                        <ListView
                            x:Name="BackupHistoryList"
                            MaxHeight="260"
                            SelectionMode="None"
                            ItemsSource="{x:Bind ViewModel.Backups, Mode=OneWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center"
                                            Text="{Binding CreatedAtText}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextTrimming="CharacterEllipsis"
                                                Text="{Binding FilePath}" />
                                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding FormattedSize}" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="2"
                                            Content="恢复"
                                            Tag="{Binding}"
                                            Click="RestoreBackup_Click" />
                                        <Button
                                            Grid.Column="3"
                                            Content="删除"
                                            Tag="{Binding}"
                                            Click="DeleteBackup_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- 数据清理（属于数据库维护） -->
                        <Border
                            Margin="0,16,0,0"
                            Padding="14"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="8">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="数据清理" />
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox
                                        Header="数据保留天数（30-365）"
                                        Minimum="30"
                                        Maximum="365"
                                        SpinButtonPlacementMode="Inline"
                                        Value="{x:Bind ViewModel.DataRetentionDays, Mode=TwoWay}" />
                                    <ToggleSwitch
                                        Grid.Column="1"
                                        Header="清理前先归档"
                                        IsOn="{x:Bind ViewModel.ArchiveBeforeCleanup, Mode=TwoWay}" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button
                                        Content="清理旧数据"
                                        Command="{x:Bind ViewModel.CleanupDataCommand}" />
                                    <ProgressBar
                                        Width="180"
                                        IsIndeterminate="True"
                                        Visibility="{x:Bind ViewModel.IsCleaningUp, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        TextWrapping="Wrap"
                                        Text="{x:Bind ViewModel.CleanupStatus, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 3. 数据导出（分析 / 转移） -->
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Glyph="&#xE896;"
                                    Foreground="#3B82F6" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="数据导出（分析 / 转移）" />
                            </StackPanel>
                        </Grid>

                        <Border
                            Padding="10"
                            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                            CornerRadius="6">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Text="用途：导出指定时间范围的数据为可读格式（JSON / Markdown / CSV / AI 提示词），适合喂给 AI 分析或迁移到其他设备。此操作不修改数据库。" />
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                            <TextBlock VerticalAlignment="Center" Text="开始日期:" />
                            <CalendarDatePicker
                                Width="160"
                                Date="{x:Bind ViewModel.ExportStartDateOffset, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center" Text="结束日期:" />
                            <CalendarDatePicker
                                Width="160"
                                Date="{x:Bind ViewModel.ExportEndDateOffset, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                Content="导出"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.ExportDataCommand}" />
                            <Button
                                Content="打开导出文件夹"
                                Command="{x:Bind ViewModel.OpenExportFolderCommand}" />
                            <ProgressBar
                                Width="180"
                                IsIndeterminate="True"
                                Visibility="{x:Bind ViewModel.IsExporting, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>

                        <TextBlock
                            FontSize="12"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            Text="{x:Bind ViewModel.ExportStatus, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <!-- 4. 云端同步（异地容灾） -->
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Glyph="&#xE753;"
                                    Foreground="#8B5CF6" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="云端同步（异地容灾）" />
                            </StackPanel>
                        </Grid>

                        <Border
                            Padding="10"
                            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                            CornerRadius="6">
                            <TextBlock FontSize="12" TextWrapping="Wrap" Text="用途：通过 WebDAV 把本地备份上传到云端（坚果云 / 群晖 / NextCloud 等）。上传的格式与本地备份一致（.zip），云端最多保留 5 份最新版本，旧版本自动清理。" />
                        </Border>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="WebDAVUrlBox"
                                Header="WebDAV 地址"
                                PlaceholderText="https://dav.example.com/PChabit" />
                            <TextBox
                                Grid.Column="1"
                                x:Name="WebDAVUsernameBox"
                                Header="用户名"
                                PlaceholderText="用户名" />
                            <PasswordBox
                                Grid.Column="2"
                                x:Name="WebDAVPasswordBox"
                                Header="密码"
                                PlaceholderText="密码" />
                        </Grid>

                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                x:Name="WebDAVEnabledBox"
                                Content="启用 WebDAV 云同步" />
                            <NumberBox
                                Grid.Column="1"
                                Header="云端最大保留份数"
                                Minimum="1"
                                Maximum="20"
                                SpinButtonPlacementMode="Inline"
                                Value="{x:Bind ViewModel.MaxCloudBackupCount, Mode=TwoWay}" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Content="测试连接"
                                Command="{x:Bind ViewModel.TestWebDAVCommand}" />
                            <Button
                                Content="保存配置"
                                Click="SaveWebDAVConfig_Click" />
                            <Button
                                Content="立即同步到云端"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.SyncToWebDAVCommand}" />
                            <ProgressBar
                                Width="180"
                                Value="{x:Bind ViewModel.UploadProgress, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsSyncing, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>

                        <TextBlock
                            FontSize="12"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            Text="{x:Bind ViewModel.WebDAVStatus, Mode=OneWay}" />

                        <!-- 云端文件列表 -->
                        <Grid Margin="0,8,0,0">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="云端文件" />
                            <Button
                                HorizontalAlignment="Right"
                                Content="刷新列表"
                                Command="{x:Bind ViewModel.BrowseRemoteBackupsCommand}" />
                        </Grid>
                        <ListView
                            x:Name="RemoteFileList"
                            MaxHeight="220"
                            SelectionMode="None"
                            ItemsSource="{x:Bind ViewModel.RemoteFiles, Mode=OneWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding FormattedSize}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding FormattedModified}" />
                                        <Button
                                            Grid.Column="3"
                                            Content="恢复"
                                            Tag="{Binding}"
                                            Click="RestoreCloud_Click" />
                                        <Button
                                            Grid.Column="4"
                                            Content="删除"
                                            Tag="{Binding}"
                                            Click="DeleteCloud_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- 5. 操作日志 -->
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Glyph="&#xE756;"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="操作日志" />
                            </StackPanel>
                            <Button
                                HorizontalAlignment="Right"
                                Content="清空"
                                Command="{x:Bind ViewModel.ClearLogsCommand}" />
                        </Grid>
                        <ListView
                            MaxHeight="200"
                            SelectionMode="None"
                            ItemsSource="{x:Bind ViewModel.OperationLogs, Mode=OneWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding FormattedTime}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource SystemAccentColor}"
                                            Text="{Binding Type}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            TextWrapping="Wrap"
                                            Text="{Binding Message}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
