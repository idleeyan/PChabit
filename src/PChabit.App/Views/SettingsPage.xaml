<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PChabit.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    mc:Ignorable="d">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="24">

            <!-- 页面标题 -->
            <TextBlock
                FontSize="24"
                FontWeight="SemiBold"
                Foreground="{StaticResource PrimaryBrush}"
                Text="设置" />

            <!-- ======================================== -->
            <!-- 基本设置                                    -->
            <!-- ======================================== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="20">
                    <!-- 分组标题 -->
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Width="32"
                                Height="32"
                                Background="{StaticResource PrimarySoftBrush}"
                                CornerRadius="6">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Glyph="&#xE713;" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="基本设置" />
                        </StackPanel>
                        <TextBlock
                            Margin="44,0,0,0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="这些设置控制应用程序的启动和显示行为"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Margin="44,0,0,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16,4">
                        <StackPanel Spacing="0">
                            <ToggleSwitch
                                x:Name="StartWithWindowsSwitch"
                                Header="开机自启动"
                                IsOn="True" />
                            <ToggleSwitch
                                x:Name="MinimizeToTraySwitch"
                                Header="最小化到系统托盘" />
                            <ToggleSwitch
                                x:Name="ShowNotificationsSwitch"
                                Header="显示通知" />
                            <ToggleSwitch
                                x:Name="AutoStartMonitoringSwitch"
                                Header="自动开始监控" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ======================================== -->
            <!-- 监控设置                                    -->
            <!-- ======================================== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Width="32"
                                Height="32"
                                Background="{StaticResource SuccessSoftBrush}"
                                CornerRadius="6">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{StaticResource SuccessBrush}"
                                    Glyph="&#xE8D1;" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="监控设置" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Margin="44,0,0,0" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="监控间隔 (分钟)" />
                            <NumberBox
                                x:Name="MonitoringIntervalBox"
                                Maximum="60"
                                Minimum="1" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="空闲阈值 (分钟)" />
                            <NumberBox
                                x:Name="IdleThresholdBox"
                                Maximum="60"
                                Minimum="1" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="44,0,0,0" Spacing="4">
                        <TextBlock FontWeight="Medium" Text="数据采集" />
                        <Border
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Margin="0,8,0,0"
                            Padding="16,4">
                            <StackPanel>
                                <ToggleSwitch
                                    x:Name="TrackKeyboardSwitch"
                                    Header="记录键盘输入" />
                                <ToggleSwitch
                                    x:Name="TrackMouseSwitch"
                                    Header="记录鼠标活动" />
                                <ToggleSwitch
                                    x:Name="TrackWebBrowsingSwitch"
                                    Header="记录网页浏览" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ======================================== -->
            <!-- 外观设置                                    -->
            <!-- ======================================== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border
                            Width="32"
                            Height="32"
                            Background="{StaticResource InsightSoftBrush}"
                            CornerRadius="6">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource InsightBrush}"
                                Glyph="&#xE790;" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="外观" />
                    </StackPanel>

                    <Grid Margin="44,0,0,0" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="主题" />
                            <ComboBox x:Name="ThemeComboBox" HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="语言" />
                            <ComboBox x:Name="LanguageComboBox" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ======================================== -->
            <!-- 数据管理                                    -->
            <!-- ======================================== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border
                                Width="32"
                                Height="32"
                                Background="{StaticResource PrimarySoftBrush}"
                                CornerRadius="6">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Glyph="&#xE74D;" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="数据管理" />
                        </StackPanel>
                        <TextBlock
                            Margin="44,0,0,0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="配置数据保留和自动清理策略，DailySummary 预聚合数据不会被清理"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Margin="44,0,0,0" Spacing="16">
                        <!-- 自动清理开关 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Text="自动清理旧数据" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="启用后自动删除超过保留天数的原始事件数据" />
                            </StackPanel>
                            <ToggleSwitch
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                IsOn="{x:Bind ViewModel.AutoCleanupEnabled, Mode=TwoWay}" />
                        </Grid>

                        <!-- 保留天数 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Text="数据保留天数" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="超过此天数的原始事件数据将被清理（30-365 天）" />
                            </StackPanel>
                            <NumberBox
                                Grid.Column="1"
                                Width="120"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Maximum="365"
                                Minimum="30"
                                SpinButtonPlacementMode="Inline"
                                Value="{x:Bind ViewModel.DataRetentionDays, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ======================================== -->
            <!-- 关于卡片                                    -->
            <!-- ======================================== -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border
                            Width="32"
                            Height="32"
                            Background="{StaticResource PrimarySoftBrush}"
                            CornerRadius="6">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource PrimaryBrush}"
                                Glyph="&#xE946;" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="关于" />
                    </StackPanel>

                    <!-- 应用信息头部 -->
                    <Border
                        Margin="44,0,0,0"
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- LOGO 占位 -->
                            <Border
                                Width="64"
                                Height="64"
                                Background="{StaticResource PrimaryBrush}"
                                CornerRadius="12">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="P" />
                            </Border>

                            <StackPanel
                                Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center"
                                Spacing="4">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="PChabit" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="电脑使用习惯追踪工具" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Spacing="6">
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 信息行 -->
                    <StackPanel Margin="44,0,0,0" Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="版本" />
                            <TextBlock
                                x:Name="VersionText"
                                Grid.Column="1"
                                FontSize="13"
                                FontWeight="Medium" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="项目地址" />
                            <HyperlinkButton
                                Grid.Column="1"
                                Padding="0"
                                Content="github.com/idleeyan/PChabit"
                                NavigateUri="https://github.com/idleeyan/PChabit" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="技术栈" />
                            <TextBlock
                                Grid.Column="1"
                                FontSize="13"
                                Text="WinUI 3 + .NET 9 + SQLite (WinAppSDK 2.2.1)" />
                        </Grid>
                    </StackPanel>

                    <!-- 使用说明 -->
                    <Border
                        Margin="44,0,0,0"
                        Padding="16"
                        Background="{StaticResource PrimarySoftBrush}"
                        CornerRadius="8">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontSize="14"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Glyph="&#xE946;" />
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Text="使用说明" />
                            </StackPanel>
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                LineHeight="20"
                                Text="PChabit 是一款电脑使用习惯追踪工具，可以记录您的应用程序使用时间、键盘鼠标活动、网页浏览历史等数据，帮助您了解自己的电脑使用习惯。"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- 操作按钮 -->
                    <StackPanel
                        Margin="44,0,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="ViewChangelogButton"
                            Click="OnViewChangelogClick"
                            CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    FontSize="12"
                                    Glyph="&#xE8A5;" />
                                <TextBlock Text="查看更新日志" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
