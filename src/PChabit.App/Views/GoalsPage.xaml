<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PChabit.App.Views.GoalsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    mc:Ignorable="d">

    <Grid Padding="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页面标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PrimaryBrush}"
                    Text="目标管理" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="为应用程序或分类设置每日使用目标，培养健康的电脑使用习惯" />
            </StackPanel>

            <Button
                HorizontalAlignment="Right"
                Click="AddGoalButton_Click"
                CornerRadius="8"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon
                        FontSize="12"
                        Glyph="&#xE710;" />
                    <TextBlock Text="添加目标" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- 主体内容 -->
        <Grid Grid.Row="1">
            <!-- 目标列表 -->
            <ListView
                x:Name="GoalsListView"
                ItemsSource="{x:Bind ViewModel.Goals, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,12" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="20"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- 目标图标 -->
                                <Border
                                    Width="48"
                                    Height="48"
                                    Background="{StaticResource PrimarySoftBrush}"
                                    CornerRadius="10">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        Foreground="{StaticResource PrimaryBrush}"
                                        Glyph="&#xE9D9;" />
                                </Border>

                                <!-- 目标详情 -->
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Text="{Binding TargetId}" />
                                        <Border
                                            Padding="8,2"
                                            Background="{StaticResource InsightBrush}"
                                            CornerRadius="10">
                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding TargetType}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE121;" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="每日限制" />
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="Medium"
                                                Foreground="{StaticResource WarningBrush}"
                                                Text="{Binding DailyLimitMinutes}" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="分钟" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 操作区域 -->
                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <ToggleSwitch
                                        Toggled="ToggleSwitch_Toggled"
                                        IsOn="{Binding IsActive, Mode=TwoWay}" />
                                    <Button
                                        Click="DeleteGoal_Click"
                                        Tag="{Binding}"
                                        Padding="8,6"
                                        CornerRadius="6"
                                        ToolTipService.ToolTip="删除目标">
                                        <FontIcon
                                            FontSize="12"
                                            Foreground="{StaticResource DangerBrush}"
                                            Glyph="&#xE74D;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 空状态 -->
            <Border
                x:Name="EmptyGoalsHint"
                Padding="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel HorizontalAlignment="Center" Spacing="16">
                    <Border
                        Width="80"
                        Height="80"
                        HorizontalAlignment="Center"
                        Background="{StaticResource PrimarySoftBrush}"
                        CornerRadius="40">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="36"
                            Foreground="{StaticResource PrimaryBrush}"
                            Glyph="&#xE9D9;" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="暂无目标" />
                    <TextBlock
                        MaxWidth="280"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="点击右上角「添加目标」按钮，为常用的应用或分类设置使用时间限制"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ProgressRing
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </Grid>

        <!-- 添加目标覆盖层 -->
        <Grid
            x:Name="AddGoalOverlay"
            Grid.RowSpan="2"
            Padding="24"
            Background="#80000000"
            Visibility="Collapsed">
            <Border
                MaxWidth="460"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border
                            Width="32"
                            Height="32"
                            Background="{StaticResource PrimarySoftBrush}"
                            CornerRadius="6">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{StaticResource PrimaryBrush}"
                                Glyph="&#xE710;" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="添加目标" />
                    </StackPanel>

                    <ComboBox
                        x:Name="TargetTypeComboBox"
                        Header="目标类型"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0">
                        <ComboBoxItem Content="应用程序" />
                        <ComboBoxItem Content="分类" />
                        <ComboBoxItem Content="总时长" />
                    </ComboBox>

                    <TextBox
                        x:Name="TargetIdTextBox"
                        Header="目标标识（应用名或分类名）"
                        PlaceholderText="例如: chrome 或 开发工具" />

                    <NumberBox
                        x:Name="DailyLimitNumberBox"
                        Header="每日限制（分钟）"
                        Maximum="1440"
                        Minimum="1"
                        Value="60" />

                    <NumberBox
                        x:Name="DailyTargetNumberBox"
                        Header="每日目标（分钟，可选）"
                        Maximum="1440"
                        Minimum="1" />

                    <StackPanel
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button
                            Click="CancelAddGoal_Click"
                            Content="取消" />
                        <Button
                            Click="ConfirmAddGoal_Click"
                            Content="添加"
                            Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
